<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      tal:omit-tag=""
      i18n:domain="plone"
>
  <metal:block use-macro="context/@@tile-form-layout/macros/master">
    <metal:block fill-slot="main">

      <h1 class="documentFirstHeading"
          i18n:translate="heading_add_new_tile"
      >Create tile</h1>

      <p class="documentDescription"
         i18n:translate="description_add_new_tile"
      >
      Select the type of tile you want to create
      </p>

      <metal:tiletypes define-macro="tiletypes">

        <div class="list-group">
          <a class="list-group-item pat-plone-modal"
             tal:repeat="tiletype view/tileTypes"
             tal:attributes="
               href string:${context/absolute_url}/@@add-tile/${tiletype/__name__};
             "
          >
            <span class="tileTitle"
                  tal:content="tiletype/title"
            >Tile type title</span>
            <small tal:content="tiletype/description">Tile type description</small>
          </a>
        </div>
      </metal:tiletypes>

    </metal:block>
  </metal:block>
</html>
